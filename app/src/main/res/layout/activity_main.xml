<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textAppearance="?attr/textAppearanceHeadlineSmall" />

        <TextView
            android:id="@+id/main_LBL_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="monospace"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:text="@string/status_placeholder" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/section_crashes"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <Button
            android:id="@+id/main_BTN_crash_npe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_crash_npe" />

        <Button
            android:id="@+id/main_BTN_crash_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_crash_state" />

        <Button
            android:id="@+id/main_BTN_crash_background"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_crash_background" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/section_non_fatal"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <Button
            android:id="@+id/main_BTN_non_fatal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_non_fatal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/section_context"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <Button
            android:id="@+id/main_BTN_breadcrumb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_breadcrumb" />

        <Button
            android:id="@+id/main_BTN_custom_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_custom_key" />

        <Button
            android:id="@+id/main_BTN_flush"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/btn_flush" />

    </LinearLayout>
</ScrollView>
