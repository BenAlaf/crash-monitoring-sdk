# Copy this file to .env (same folder) and fill in the values from MongoDB Atlas.
# .env is gitignored — never commit real credentials.

# Host part of the Atlas connection string, WITHOUT the mongodb+srv:// prefix
# and WITHOUT username/password. Example: cluster0.ab1cd.mongodb.net
DB_CONNECTION_STRING=

# Database name (keep as is unless you prefer another)
DB_NAME=crash_monitor

# The database user you create in Atlas (Security Quickstart / Database Access)
DB_USERNAME=
DB_PASSWORD=

# Invent a long random string — this is the portal/admin password.
# The same value must later be set in Vercel's environment variables.
ADMIN_KEY=
